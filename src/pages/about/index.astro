</BaseLayout>

<style>
  .about-intro {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(260px, 400px);
    align-items: start;
    gap: clamp(2rem, 6vw, 6rem);
  }

  .about-portrait {
    width: 100%;
    max-width: 400px;
    object-fit: cover;
    justify-self: end;
    object-position: center 60%;
    /* aspect-ratio: 3 /4; */
  }

  @media (max-width: 760px) {
    .about-intro {
      grid-template-columns: 1fr;
    }

    .about-portrait {
      max-width: 360px;
      justify-self: start;
    }
  }
</style>
