---
import "@fontsource-variable/fraunces/opsz.css";
import "@fontsource/public-sans/400.css";
import "@fontsource/public-sans/500.css";
import "@fontsource/public-sans/600.css";
import "@fontsource/public-sans/700.css";
import "@fontsource-variable/jetbrains-mono/wght.css";
import "../styles/global.css";
import { withBase } from "../lib/url";
import { SITE, NAV_ITEMS } from "../consts";
import { faGithub, faLinkedin } from "@fortawesome/free-brands-svg-icons";

interface Props {
  title?: string;
  description?: string;
  ogType?: "website" | "article";
  image?: string;
}

const siteName = SITE.title;

const {
  title = siteName,
  description = SITE.description,
  ogType = "website",
  image,
} = Astro.props;

// `Astro.site` comes from `site` in astro.config.mjs; fall back to the
// request URL during dev so canonical/OG links still resolve.
const siteBase = Astro.site ?? new URL(Astro.url.origin);
const canonicalURL = new URL(Astro.url.pathname, siteBase);
const imageURL = image
  ? new URL(image, siteBase)
  : new URL(withBase(SITE.ogImage), siteBase);
const fullTitle = title === siteName ? title : `${title} — ${siteName}`;

const currentPath = Astro.url.pathname;
const isActive = (href: string) => {
  const full = withBase(href);
  return href === "/" ? currentPath === full : currentPath.startsWith(full);
};

const githubPath = Array.isArray(faGithub.icon[4])
  ? faGithub.icon[4][0]
  : faGithub.icon[4];
const linkedinPath = Array.isArray(faLinkedin.icon[4])
  ? faLinkedin.icon[4][0]
  : faLinkedin.icon[4];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href={withBase("/favicon.svg")} />
    <link rel="icon" href={withBase("/favicon.ico")} />
    <link rel="canonical" href={canonicalURL} />
    <link rel="sitemap" href={withBase("/sitemap-index.xml")} />
    <link
      rel="alternate"
      type="application/rss+xml"
      title={siteName}
      href={withBase("/rss.xml")}
    />
    <title>{fullTitle}</title>

    <!-- Open Graph -->
    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    {imageURL && <meta property="og:image" content={imageURL} />}

    <!-- Twitter -->
    <meta
      name="twitter:card"
      content={imageURL ? "summary_large_image" : "summary"}
    />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    {imageURL && <meta name="twitter:image" content={imageURL} />}
    <script is:inline>
      const storedTheme = localStorage.getItem("theme");
      const prefersDark = window.matchMedia(
        "(prefers-color-scheme: dark)",
      ).matches;
      document.documentElement.dataset.theme =
        storedTheme || (prefersDark ? "dark" : "light");
    </script>
  </head>
  <body>
    <header class="site-header">
      <a class="brand" href={withBase("/")} aria-label={`${siteName} home`}>
        <span class="brand-mark" aria-hidden="true"></span>
        <span>{siteName}</span>
      </a>
      <nav class="site-nav" aria-label="Main navigation">
        {
          NAV_ITEMS.map((item) => (
            <a
              href={withBase(item.href)}
              aria-current={isActive(item.href) ? "page" : undefined}
            >
              {item.label}
            </a>
          ))
        }
      </nav>
      <button
        class="theme-toggle"
        type="button"
        aria-label="Toggle color theme"
        data-theme-toggle
      >
        <span aria-hidden="true"></span>
      </button>
    </header>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <p>{SITE.footerText}</p>

      <nav class="footer-socials">
        <a
          class="footer-social-link"
          href="https://github.com/knjk04"
          target="_blank"
          rel="me noopener noreferrer"
          aria-label="Karan Kumar's GitHub profile"
        >
          <svg
            aria-hidden="true"
            viewBox={`0 0 ${faGithub.icon[0]} ${faGithub.icon[1]}`}
            width="20"
            height="20"
            fill="currentColor"
          >
            <path d={githubPath}></path>
          </svg>
        </a>
        <a
          class="footer-social-link"
          href="https://www.linkedin.com/in/karan-n-j-kumar/"
          target="_blank"
          rel="me noopener noreferrer"
          aria-label="Karan Kumar's LinkedIn profile"
        >
          <svg
            aria-hidden="true"
            viewBox={`0 0 ${faLinkedin.icon[0]} ${faLinkedin.icon[1]}`}
            width="20"
            height="20"
            fill="currentColor"
          >
            <path d={linkedinPath}></path>
          </svg>
        </a>
      </nav>
    </footer>

    <script>
      const toggle = document.querySelector("[data-theme-toggle]");
      toggle?.addEventListener("click", () => {
        const current = document.documentElement.dataset.theme;
        const next = current === "dark" ? "light" : "dark";
        document.documentElement.dataset.theme = next;
        localStorage.setItem("theme", next);
      });
    </script>
  </body>
</html>
