---
import BaseLayout from "../layouts/BaseLayout.astro";
import { Image } from "astro:assets";
import { getCollection } from "astro:content";
import { withBase } from "../lib/url";

const projects = (await getCollection("projects"))
  .sort((a, b) => {
    const byDate = b.data.publishDate.getTime() - a.data.publishDate.getTime();
    return byDate || (a.data.order ?? 999) - (b.data.order ?? 999);
  })
  .slice(0, 3);

const posts = (await getCollection("blog"))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime())
  .slice(0, 3);

const formatDate = (date: Date) =>
  new Intl.DateTimeFormat("en", {
    month: "short",
    day: "numeric",
    year: "numeric",
  }).format(date);
---

<BaseLayout
  title="Astro Keel"
  description="A minimal portfolio and writing theme for careful technical work."
>
  <section class="hero section">
    <!-- <p class="eyebrow">Portfolio / writing / systems notes</p> -->
    <h1>Karan Kumar</h1>
    <p class="lead">
      Product-minded Software Engineer building scalable, reliable software
      <br />
      that solves real user problems.
    </p>
    <div class="action-row" aria-label="Primary links">
      <a class="button" href={withBase("/projects/")}>View projects</a>
      <a class="text-link" href={withBase("/blog/")}>Read my writing</a>
    </div>
  </section>

  <!-- <section class="section split-overview" aria-label="Theme overview">
    <div>
      <p class="eyebrow">Principles</p>
      <h2>Readable first, decorative last.</h2>
    </div>
    <div class="feature-list">
      <article>
        <h3>Baseline rhythm</h3>
        <p>Vertical spacing follows a steady cadence for long-form reading.</p>
      </article>
      <article>
        <h3>Typed content</h3>
        <p>
          Collections are prepared for project case studies and durable notes.
        </p>
      </article>
      <article>
        <h3>Keel lines</h3>
        <p>
          Fine rules create structure without relying on decorative effects.
        </p>
      </article>
    </div>
  </section> -->

  <section class="section index-feed" aria-labelledby="latest-projects">
    <div class="section-heading">
      <p class="eyebrow">Latest projects</p>
      <h2 id="latest-projects">My projects.</h2>
      <a class="text-link" href={withBase("/projects/")}>All projects</a>
    </div>

    {
      projects.length > 0 ? (
        <div class="highlight-grid">
          {projects.map((project) => (
            <article class="highlight-card">
              {project.data.thumbnail && (
                <Image
                  src={project.data.thumbnail}
                  alt=""
                  width={720}
                  height={480}
                  loading="lazy"
                />
              )}
              <div>
                <p class="meta">{formatDate(project.data.publishDate)}</p>
                <h3>
                  <a href={withBase(`/projects/${project.id}/`)}>
                    {project.data.title}
                  </a>
                </h3>
                <p>{project.data.description}</p>
                {project.data.tech.length > 0 && (
                  <ul
                    class="tag-list"
                    aria-label={`${project.data.title} technology`}
                  >
                    {project.data.tech.slice(0, 4).map((tech) => (
                      <li>{tech}</li>
                    ))}
                  </ul>
                )}
              </div>
            </article>
          ))}
        </div>
      ) : (
        <div class="empty-state compact">
          <p>
            Add projects under <code>src/content/projects</code> to surface the
            latest projects here.
          </p>
        </div>
      )
    }
  </section>

  <section class="section index-feed" aria-labelledby="latest-notes">
    <div class="section-heading">
      <p class="eyebrow">Latest blog</p>
      <h2 id="latest-notes">Writing.</h2>
      <a class="text-link" href={withBase("/blog/")}>All posts</a>
    </div>

    {
      posts.length > 0 ? (
        <div class="note-list">
          {posts.map((post) => (
            <article class="note-row">
              {post.data.heroImage && (
                <Image
                  src={post.data.heroImage}
                  alt=""
                  width={320}
                  height={220}
                  loading="lazy"
                />
              )}
              <div>
                <p class="meta">{formatDate(post.data.publishDate)}</p>
                <h3>
                  <a href={withBase(`/blog/${post.id}/`)}>{post.data.title}</a>
                </h3>
                <p>{post.data.description}</p>
              </div>
            </article>
          ))}
        </div>
      ) : (
        <div class="empty-state compact">
          <p>No blog posts found. Stay tuned for updates!</p>
        </div>
      )
    }
  </section>
</BaseLayout>
